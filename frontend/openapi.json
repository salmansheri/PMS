{
  "openapi": "3.0.0",
  "info": {
    "title": "TokyoClinic OS API",
    "description": "REST API contract specification for patient intake, scheduling, consultation, and live queue flows.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api",
      "description": "Local Development Server"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate Operator Node",
        "description": "Verifies staff credentials and returns a secure HttpOnly session cookie containing the JWT.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session established successfully.",
            "headers": {
              "Set-Cookie": {
                "description": "HTTP-Only secure cookie containing the authentication token.",
                "schema": {
                  "type": "string",
                  "example": "token=eyJhbGc...; Path=/api; Max-Age=86400; HttpOnly; Secure; SameSite=Strict"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials provided."
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Terminate Session",
        "description": "Evicts the JWT cookie and publishes a logout event to the audit trail.",
        "responses": {
          "200": {
            "description": "Session terminated, cookie cleared.",
            "headers": {
              "Set-Cookie": {
                "description": "Cleared token cookie.",
                "schema": {
                  "type": "string",
                  "example": "token=; Path=/api; Max-Age=0; HttpOnly; Secure; SameSite=Strict"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Register Staff Node",
        "description": "Creates a new clinic staff account. Restricted to ROLE_ADMIN.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Staff registered successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Username already taken or invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions (requires Admin role)."
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get Current Profile",
        "description": "Returns details of the currently authenticated operator.",
        "responses": {
          "200": {
            "description": "Operator profile details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Session expired or missing JWT cookie."
          }
        }
      }
    },
    "/patients": {
      "post": {
        "summary": "Register Patient (Intake)",
        "description": "Performs patient intake and demographic registration. SSN is automatically masked.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Patient registered successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "403": {
            "description": "Requires ROLE_RECEPTIONIST or ROLE_ADMIN."
          }
        }
      }
    },
    "/patients/{id}": {
      "get": {
        "summary": "Get Patient Details",
        "description": "Retrieves demographic details. Cached in Redis for 1 hour.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient records retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "404": {
            "description": "Patient not found."
          }
        }
      },
      "put": {
        "summary": "Update Patient Profile",
        "description": "Updates details and evicts the corresponding Redis patient cache entry.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient profile updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "404": {
            "description": "Patient not found."
          }
        }
      }
    },
    "/patients/search": {
      "get": {
        "summary": "Search Patients",
        "description": "Performs case-insensitive search by patient name.",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results array.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Patient"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/patients/{id}/records": {
      "post": {
        "summary": "Add Medical Record",
        "description": "Appends a consultation record. Custom assessments/vitals are sent in a dynamic JSON structure. Restricted to ROLE_DOCTOR, ROLE_ADMIN.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MedicalRecordRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Consultation record saved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicalRecord"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get Patient Consultation History",
        "description": "Retrieves all consultation records for the patient, ordered by date descending. Restricted to ROLE_DOCTOR, ROLE_ADMIN.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "History records array.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MedicalRecord"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/doctors": {
      "get": {
        "summary": "List Doctors",
        "description": "Lists active registered doctors. Cached in Redis for 1 hour.",
        "responses": {
          "200": {
            "description": "Active doctor directory list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DoctorResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/appointments": {
      "post": {
        "summary": "Book Appointment",
        "description": "Schedules a doctor consultation. Rejects booking if there is a scheduling conflict within a 30-minute window. Uses optimistic locking.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Appointment booked successfully. Async SMS alert dispatched.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Appointment"
                }
              }
            }
          },
          "400": {
            "description": "Validation errors or scheduling conflict."
          }
        }
      }
    },
    "/appointments/doctor/{doctorId}": {
      "get": {
        "summary": "Get Doctor Schedule",
        "description": "Lists appointments assigned to the doctor, ordered by time ascending.",
        "parameters": [
          {
            "name": "doctorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Assigned appointments array.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Appointment"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/appointments/{id}/status": {
      "put": {
        "summary": "Update Appointment Status",
        "description": "Transitions slot state (e.g. to CANCELLED). Rejects transition if slot is already cancelled or completed.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["SCHEDULED", "CANCELLED", "COMPLETED"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Appointment slot updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Appointment"
                }
              }
            }
          }
        }
      }
    },
    "/queue/check-in": {
      "post": {
        "summary": "Check-In (Enqueue)",
        "description": "Checks in a patient and issues the next sequential token number. Rejects if patient is already active in queue.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueueRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Token issued, queued in WAITING state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueItem"
                }
              }
            }
          }
        }
      }
    },
    "/queue/doctor/{doctorId}": {
      "get": {
        "summary": "Get Doctor Queue Lane",
        "description": "Retrieves the active queue list (WAITING and ACTIVE) assigned to the doctor.",
        "parameters": [
          {
            "name": "doctorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of active queue items.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QueueItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/queue/{id}/call": {
      "put": {
        "summary": "Call Patient",
        "description": "Sets status to ACTIVE. Dispatches async SMS notifying the patient to proceed to the room. Restricted to ROLE_DOCTOR, ROLE_ADMIN.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient status updated to calling.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueItem"
                }
              }
            }
          }
        }
      }
    },
    "/queue/{id}/complete": {
      "put": {
        "summary": "Complete Consultation",
        "description": "Sets status to COMPLETED and evicts patient queue item details. Restricted to ROLE_DOCTOR, ROLE_ADMIN.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Consultation finalized, patient removed from active list.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueItem"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "example": "receptionist"
          },
          "password": {
            "type": "string",
            "example": "recept123"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "password", "role", "fullName"],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["ROLE_ADMIN", "ROLE_DOCTOR", "ROLE_RECEPTIONIST"]
          },
          "fullName": {
            "type": "string"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          }
        }
      },
      "PatientRequest": {
        "type": "object",
        "required": ["name", "dateOfBirth", "gender", "ssn", "phone", "email"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "1994-10-27"
          },
          "gender": {
            "type": "string",
            "example": "FEMALE"
          },
          "ssn": {
            "type": "string",
            "example": "999-12-3456"
          },
          "phone": {
            "type": "string",
            "example": "+81-90-1234-5678"
          },
          "email": {
            "type": "string",
            "example": "jane.doe@example.com"
          },
          "bloodType": {
            "type": "string",
            "example": "O_POSITIVE"
          },
          "emergencyContactName": {
            "type": "string",
            "example": "John Doe"
          },
          "emergencyContactPhone": {
            "type": "string",
            "example": "+81-80-8765-4321"
          }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "gender": {
            "type": "string"
          },
          "ssnMasked": {
            "type": "string",
            "example": "***-**-3456"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "bloodType": {
            "type": "string"
          },
          "emergencyContactName": {
            "type": "string"
          },
          "emergencyContactPhone": {
            "type": "string"
          }
        }
      },
      "MedicalRecordRequest": {
        "type": "object",
        "required": ["conditions", "allergies", "vitals"],
        "properties": {
          "conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allergies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "vitals": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "MedicalRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "patientId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allergies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "vitals": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "DoctorResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          }
        }
      },
      "AppointmentRequest": {
        "type": "object",
        "required": ["patientId", "doctorId", "appointmentTime"],
        "properties": {
          "patientId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "appointmentTime": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "patientId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "appointmentTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          }
        }
      },
      "QueueRequest": {
        "type": "object",
        "required": ["patientId", "doctorId"],
        "properties": {
          "patientId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "QueueItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "patientId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "tokenNumber": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "checkedInTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
